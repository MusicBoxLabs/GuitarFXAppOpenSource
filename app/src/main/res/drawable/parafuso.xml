<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <gradient android:type="radial" android:gradientRadius="10"
                android:startColor="#5A5148" android:endColor="#2A241E"/>
            <stroke android:width="1dp" android:color="#0E0B08"/>
        </shape>
    </item>
    <item android:top="5dp" android:bottom="5dp" android:left="1dp" android:right="1dp">
        <shape android:shape="rectangle"><solid android:color="#1A1611"/></shape>
    </item>
</layer-list>
